# ==============================================================================
# P2-1 Auth middleware
# ==============================================================================
# Session cookie signing key. HMAC-SHA256 over session payloads.
# Generate a new key with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Must be at least 32 bytes of entropy (256-bit). base64url encoded.
# NEVER commit the real value. Keep in .env.local (git-ignored) and Vercel env.
COOKIE_SIGNING_KEY=
